APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/app.log
DATABASE_PATH=data/campus_agent.db

# mock | openai_compatible
LLM_PROVIDER=mock
LLM_MODEL=EmoLLM-2.0
LLM_BASE_URL=http://127.0.0.1:23333/v1
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=512

# disabled | mock | openai_compatible
STT_PROVIDER=mock
STT_MODEL=whisper-1
STT_BASE_URL=http://127.0.0.1:8001/v1
STT_API_KEY=
STT_LANGUAGE=zh

CAMPUS_NAME=示例大学
CAMPUS_COUNSELING_CENTER=学生心理中心
CAMPUS_COUNSELING_HOTLINE=请替换为你学校心理热线
CAMPUS_COUNSELING_EMAIL=psy-center@example.edu
CAMPUS_KB_PATH=data/campus_knowledge.json

CRISIS_CONTACTS=当地紧急电话,校心理中心值班电话,可信任辅导员/班主任/家长
